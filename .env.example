# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Signal sources ---
# Built-in sources: dexscreener, geckoterminal, custom
# You can list multiple, comma separated. Order = priority.
SIGNAL_SOURCES=dexscreener,geckoterminal
SIGNAL_POLL_MS=30000

# Optional custom Charon-style server (if you run one)
SIGNAL_SERVER_URL=
SIGNAL_SERVER_KEY=

# DexScreener / GeckoTerminal are public, no key required
DEXSCREENER_BASE_URL=https://api.dexscreener.com
GECKOTERMINAL_BASE_URL=https://api.geckoterminal.com/api/v2

# --- Base RPC ---
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=
# Optional Alchemy/QuickNode key if you prefer
ALCHEMY_API_KEY=

# --- Wallet (only needed for live / confirm modes) ---
EVM_PRIVATE_KEY=
LIVE_MIN_ETH_RESERVE=0.005

# --- Execution ---
TRADING_MODE=dry_run            # dry_run | confirm | live
ROUTER=zeroex                   # zeroex | uniswap
ZEROEX_BASE_URL=https://base.api.0x.org
ZEROEX_API_KEY=
UNISWAP_ROUTER_ADDRESS=0x2626664c2603336E57B271c5C0b26F421741e481  # Uniswap V3 SwapRouter02 on Base
DEFAULT_SLIPPAGE_BPS=200        # 2%
DEFAULT_BUY_ETH=0.01
POSITION_CHECK_MS=10000

# --- LLM ---
ENABLE_LLM=true
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=60000
LLM_CANDIDATE_PICK_COUNT=10
LLM_CANDIDATE_MAX_AGE_MS=600000

# --- Storage ---
DB_PATH=./charon-base.sqlite
